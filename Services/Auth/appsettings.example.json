{
  "Urls": "https://localhost:7189;http://localhost:5189",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=LiteChat;Username=your_user;Password=your_password"
